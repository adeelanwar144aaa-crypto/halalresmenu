# Copy to `.env.local` and fill in values.

NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional: local seeding when RLS blocks anon INSERT (server / scripts only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=
# Production URL; use http://localhost:PORT for dev so links use http://slug.localhost:PORT (wildcard subdomains).
NEXT_PUBLIC_SITE_URL=https://halalresmenu.com
# Optional: apex domain for subdomain routing if SITE_URL is not the bare domain (e.g. preview URL). Example: halalresmenu.com
# NEXT_PUBLIC_ROOT_DOMAIN=halalresmenu.com
GOOGLE_PLACES_API_KEY=your-google-api-key
# Foursquare Places API v3 (Authorization header value) — scripts/extract-foursquare-halal.js
FOURSQUARE_API_KEY=your-foursquare-api-key
# Optional if Just Eat returns 403: JE-API-KEY value from Foursquare developer portal
# JUST_EAT_API_KEY=
CLAUDE_API_KEY=your-claude-api-key
ALADHAN_API_KEY=
