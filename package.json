    "worker:build": "npx @cloudflare/next-on-pages --outdir .worker-next",
    "deploy": "npm run worker:build && wrangler deploy",
    "start": "next start",
    "lint": "next lint",
    "seed": "npx tsx scripts/seed.ts",
    "extract": "node scripts/extract-uk-halal-restaurants.js",
    "extract-fsq": "node scripts/extract-foursquare-halal.js",
    "extract-fsq:test": "node scripts/extract-foursquare-halal.js --test",
    "extract-osm2": "node scripts/extract-osm-extended.js",
    "extract-justeat": "node scripts/extract-justeat.js",
    "scrape-deliveroo-menu": "node scripts/deliveroo-menu-scraper.js",
    "scrape-menu-smart": "node scripts/menu-scraper-smart.js",
    "db:menu-data": "node -e \"console.log('Run scripts/migrations/add-menu-data-column.sql in the Supabase SQL editor.')\"",
    "db:seo-content": "node -e \"console.log('Run scripts/migrations/add-seo-content-column.sql in the Supabase SQL editor.')\"",
    "enrich-google": "node scripts/google-places-enrichment.js",
    "facebook-photos": "node scripts/facebook-photos.js",
    "foursquare-photos": "node scripts/foursquare-photos.js",
    "download-photos-mosques": "node scripts/download-photos-and-mosques.js",
    "db:nearby-mosques": "node -e \"console.log('Run scripts/migrations/add-nearby-mosques-column.sql in the Supabase SQL editor.')\"",
    "website-images": "node scripts/website-images.js",
    "db:takeaway-defaults": "node -e \"console.log('Run scripts/migrations/set-has-takeaway-delivery.sql in the Supabase SQL editor.')\"",
    "db:google-places": "node -e \"console.log('Run scripts/migrations/add-google-places-columns.sql in the Supabase SQL editor.')\"",
    "db:meta-tags": "node -e \"console.log('Run scripts/migrations/add-meta-tags-columns.sql in the Supabase SQL editor.')\"",
    "generate-meta-tags": "node scripts/generate-meta-tags.js"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.7",
    "@supabase/supabase-js": "^2.49.1",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "next": "^15.1.0",
    "node-fetch": "^2.7.0",
    "puppeteer": "^24.43.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "string-similarity": "^4.0.4",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "dotenv": "^16.4.7",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vercel": "^47.0.4",
    "wrangler": "^4.98.0"
  }
